{
  "name": "tab-manager-v2",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "preinstall": "npx only-allow pnpm",
    "start": "pnpm --filter tab-manager-v2 start",
    "capture:release-screenshots": "pnpm --filter integration-test exec node scripts/capture-release-screenshots.mjs",
    "release": "pnpm --filter tab-manager-v2 exec standard-version",
    "release-it": "release-it --ci",
    "test": "run-s test:unit test:integration",
    "test:lint": "pnpm lint",
    "test:unit": "pnpm --filter tab-manager-v2 test",
    "test:integration": "run-s test:integration:build test:integration:run",
    "test:integration:build": "pnpm --filter tab-manager-v2 build:chrome",
    "test:integration:run": "pnpm --filter integration-test test",
    "test:chrome-upload": "chrome-webstore-upload --help",
    "test:firefox-upload": "web-ext --help",
    "build": "pnpm --filter tab-manager-v2 build",
    "deploy": "run-s build zip ls stat",
    "deploy:chrome": "run-s deploy:chrome:*",
    "deploy:chrome:build": "pnpm --filter tab-manager-v2 build:chrome",
    "deploy:chrome:zip": "pnpm --filter tab-manager-v2 zip:chrome",
    "deploy:chrome:ls": "pnpm --filter tab-manager-v2 ls:chrome",
    "deploy:chrome:stat": "pnpm --filter tab-manager-v2 stat:chrome",
    "publish:chrome": "chrome-webstore-upload --source packages/extension/build/build_chrome.zip",
    "publish:firefox": "web-ext sign --source-dir packages/extension/build/build_firefox --channel=listed || echo 'Publish to Mozilla Add-ons may failed because https://github.com/mozilla/web-ext/issues/804'",
    "publish:edge": "node ./publish_edge.mjs",
    "publish-extension": "run-s publish:chrome publish:firefox publish:edge",
    "zip": "pnpm --filter tab-manager-v2 zip",
    "ls": "pnpm --filter tab-manager-v2 ls",
    "stat": "pnpm --filter tab-manager-v2 stat",
    "lint": "eslint .",
    "prettier": "prettier --write",
    "lintfix": "pnpm prettier '**/*.{js,ts,tsx,yml}' && pnpm lint --fix"
  },
  "devDependencies": {
    "@plasmohq/edge-addons-api": "^2.0.0",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "chrome-webstore-upload-cli": "3.5.0",
    "coveralls": "3.1.1",
    "dotenv": "16.6.1",
    "eslint": "9.39.3",
    "eslint-config-prettier": "9.1.2",
    "eslint-plugin-jest": "28.14.0",
    "husky": "9.1.7",
    "lint-staged": "15.5.2",
    "npm-run-all2": "7.0.2",
    "prettier": "3.8.1",
    "release-it": "18.1.2",
    "typescript": "5.9.3",
    "web-ext": "8.10.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "pnpm prettier",
      "eslint --fix"
    ],
    "*.{json,css,md,md,mdx,html}": [
      "pnpm prettier"
    ]
  },
  "packageManager": "pnpm@9.15.9"
}
