{
  "name": "tab-manager-v2",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "preinstall": "npx only-allow pnpm",
    "start": "pnpm --filter tab-manager-v2 start",
    "capture:release-screenshots": "pnpm --filter integration-test exec node scripts/capture-release-screenshots.mjs",
    "convert:release-screenshots": "pnpm --filter integration-test exec node scripts/convert-release-screenshots-to-webp.mjs",
    "build:release-screenshots": "run-s capture:release-screenshots convert:release-screenshots",
    "capture:feature-videos": "pnpm --filter integration-test exec node scripts/capture-feature-videos.mjs",
    "capture:integration-test-video": "pnpm --filter integration-test exec node scripts/capture-integration-test-suite-video.mjs",
    "build:feature-promo-video": "pnpm --filter integration-test exec node scripts/build-feature-promo-video.mjs",
    "build:feature-videos": "run-s capture:feature-videos build:feature-promo-video",
    "build:integration-test-video": "run-s test:integration:build capture:integration-test-video",
    "build:promotional-tiles": "node ./promotional_tiles/render.mjs",
    "build:docs-posters": "pnpm --filter integration-test exec node scripts/render-docs-posters.mjs",
    "build:marketing-artwork": "run-s build:promotional-tiles build:docs-posters",
    "sync:release-secrets": "node ./scripts/sync-release-secrets-to-github.mjs",
    "release:releasability": "node ./scripts/audit-release-please-releasability.mjs",
    "test": "run-s test:unit test:integration",
    "test:lint": "pnpm lint",
    "test:unit": "pnpm --filter tab-manager-v2 test",
    "test:integration": "run-s test:integration:build test:integration:run",
    "test:integration:build": "pnpm --filter tab-manager-v2 build:chrome",
    "test:integration:run": "pnpm --filter integration-test test",
    "test:chrome-upload": "node ./publish_chrome.mjs --help",
    "test:firefox-upload": "web-ext --help",
    "build": "pnpm --filter tab-manager-v2 build",
    "deploy": "run-s build zip ls stat",
    "deploy:chrome": "run-s deploy:chrome:*",
    "deploy:chrome:build": "pnpm --filter tab-manager-v2 build:chrome",
    "deploy:chrome:zip": "pnpm --filter tab-manager-v2 zip:chrome",
    "deploy:chrome:ls": "pnpm --filter tab-manager-v2 run ls:chrome",
    "deploy:chrome:stat": "pnpm --filter tab-manager-v2 stat:chrome",
    "package:firefox-source": "git archive --format=zip --output packages/extension/build/build_firefox_source.zip HEAD",
    "publish:chrome": "node ./publish_chrome.mjs",
    "publish:firefox": "run-s package:firefox-source publish:firefox:sign",
    "publish:firefox:sign": "web-ext sign --source-dir packages/extension/build/build_firefox --channel=listed --upload-source-code packages/extension/build/build_firefox_source.zip --approval-timeout 0",
    "publish:edge": "node ./publish_edge.mjs",
    "publish-extension": "run-s publish:chrome publish:firefox publish:edge",
    "zip": "pnpm --filter tab-manager-v2 zip",
    "ls": "pnpm --filter tab-manager-v2 run ls",
    "stat": "pnpm --filter tab-manager-v2 stat",
    "lint": "eslint .",
    "prettier": "prettier --write",
    "lintfix": "pnpm prettier '**/*.{js,ts,tsx,yml}' && pnpm lint --fix"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.3",
    "@plasmohq/edge-addons-api": "^2.0.0",
    "@typescript-eslint/eslint-plugin": "8.58.0",
    "@typescript-eslint/parser": "8.58.0",
    "chrome-webstore-upload-cli": "3.5.0",
    "dotenv": "16.6.1",
    "eslint": "9.39.4",
    "eslint-config-prettier": "9.1.2",
    "eslint-plugin-jest": "28.14.0",
    "husky": "9.1.7",
    "lint-staged": "15.5.2",
    "npm-run-all2": "7.0.2",
    "prettier": "3.8.1",
    "typescript": "5.9.3",
    "web-ext": "10.1.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "pnpm prettier",
      "eslint --fix"
    ],
    "*.{json,css,md,md,mdx,html}": [
      "pnpm prettier"
    ]
  },
  "pnpm": {
    "overrides": {
      "@babel/runtime@7.26.0": "7.29.2",
      "@tootallnate/once@2.0.0": "3.0.1",
      "ajv@6.12.6": "6.14.0",
      "ajv@8.17.1": "8.18.0",
      "brace-expansion@1.1.11": "1.1.13",
      "brace-expansion@2.0.1": "2.0.3",
      "brace-expansion@5.0.4": "5.0.5",
      "diff@3.5.0": "3.5.1",
      "flatted@3.3.2": "3.4.2",
      "form-data@4.0.0": "4.0.4",
      "glob@10.4.5": "10.5.0",
      "glob@11.0.0": "11.1.0",
      "handlebars@4.7.8": "4.7.9",
      "happy-dom@15.11.7": "20.8.9",
      "js-yaml@3.14.1": "3.14.2",
      "js-yaml@4.1.0": "4.1.1",
      "lodash@4.17.21": "4.17.23",
      "minimatch@3.1.2": "3.1.5",
      "minimatch@9.0.5": "9.0.7",
      "minimatch@10.0.1": "10.2.4",
      "path-to-regexp@0.1.12": "0.1.13",
      "path-to-regexp@8.2.0": "8.4.1",
      "picomatch@2.3.1": "2.3.2",
      "qs@6.13.0": "6.14.2",
      "qs@6.14.1": "6.14.2",
      "ws@8.14.2": "8.20.0",
      "ws@8.18.0": "8.20.0",
      "yaml@1.10.2": "1.10.3",
      "yaml@2.8.2": "2.8.3"
    }
  },
  "packageManager": "pnpm@10.32.1"
}
